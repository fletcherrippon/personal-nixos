home/dotfiles/waybar/colors.css
home/dotfiles/hypr/conf.d/00-theme.conf
home/dotfiles/fuzzel/fuzzel.ini
home/dotfiles/mako/config

# macOS
.DS_Store

# home-manager backups
*.bak
