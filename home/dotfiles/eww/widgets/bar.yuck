;; The top bar: assembles the module widgets (each defined in its own widgets/
;; file and pulled in by eww.yuck).
(defwidget bar []
  (centerbox :class "bar"
    (box :halign "start" :valign "center" :space-evenly false :spacing 10
      (launcher) (workspaces) (apps))
    (box)
    (box :halign "end" :valign "center" :space-evenly false :spacing 10
      (clock) (power))))
