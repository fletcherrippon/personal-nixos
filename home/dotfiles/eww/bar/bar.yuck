(include "./bar/launcher.yuck")
(include "./bar/workspaces.yuck")
(include "./bar/apps.yuck")
(include "./bar/clock.yuck")
(include "./bar/power.yuck")

(defwidget bar []
  (centerbox :class "bar"
    (box :halign "start" :valign "center" :space-evenly false :spacing 10
      (launcher) (workspaces) (apps))
    (box)
    (box :halign "end" :valign "center" :space-evenly false :spacing 10
      (clock) (power))))
