;; Windows attach widgets to the screen.
(defwindow topbar
  :monitor 0
  :geometry (geometry :x "0" :y "0" :width "100%" :height "40px" :anchor "top center")
  :stacking "fg"
  :exclusive true
  (bar))

(defwindow sidecard
  :monitor 0
  :geometry (geometry :x "20px" :y "20px" :anchor "bottom right" :width "230px")
  :stacking "fg"
  (card))
